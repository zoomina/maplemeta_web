# PostgreSQL 연결 정보 (Supabase Session Pooler 사용)
# fly.io 배포 시 민감 정보는 fly secrets set 으로 관리
PGHOST=aws-0-your-region.pooler.supabase.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres.your-project-ref
PGPASSWORD=change_me
PGSCHEMA=public

# 앱 설정
APP_NAME=Maple Meta Dashboard

# Supabase 프로젝트 URL (직업 디테일 캐릭터 이미지: character-images 버킷 public URL 생성에 사용)
# 예: https://xxxxxxxx.supabase.co
SUPABASE_URL=

# 패치노트 파일 경로 (로컬 개발 시 사용)
PATCH_NOTE_BASE_PATH=
